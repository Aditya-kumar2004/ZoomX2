# Dependency directories
**/node_modules/
**/bower_components/

# Next.js build output and cache
**/.next/
**/out/

# Python virtual environments
**/venv/
**/.venv/
**/env/
**/.env/

# Python cache and compiled files
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Local environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs and system dumps
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
**/*.stackdump
**/*.log

# IDE files and OS configurations
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# Database (optional)
**/db.sqlite3
